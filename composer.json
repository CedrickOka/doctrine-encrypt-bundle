{
    "name" : "coka/doctrine-encrypt-bundle",
    "type" : "symfony-bundle",
    "license" : "MIT",
    "description" : "Encrypted doctrine type value with openssl.",
    "homepage" : "https://github.com/CedrickOka/doctrine-encrypt-bundle",
    "keywords" : [
        "doctrine",
        "openssl"
    ],
    "autoload" : {
        "psr-4" : {
            "Oka\\Doctrine\\EncryptBundle\\" : "src/"
        },
        "exclude-from-classmap" : [
            "/tests/"
        ]
    },
    "autoload-dev" : {
        "psr-4" : {
            "Oka\\Doctrine\\EncryptBundle\\Tests\\" : "tests/"
        }
    },
    "require" : {
        "php" : ">=8.0",
        "symfony/config" : "^4.4 || ^5.4 || ^6.4 || ^7.4",
        "symfony/dependency-injection" : "^4.4 || ^5.4 || ^6.4 || ^7.4",
        "symfony/http-kernel" : "^4.4 || ^5.4 || ^6.4 || ^7.4"
    },
    "require-dev" : {
        "doctrine/mongodb-odm-bundle": "^3.0 || ^4.7 || ^5.6",
        "doctrine/orm": "^2.4.8",
        "friendsofphp/php-cs-fixer" : "^3",
        "symfony/framework-bundle" : "^4.4 || ^5.4 || ^6.4 || ^7.4",
        "symfony/phpunit-bridge" : "^4.4 || ^5.4 || ^6.4 || ^7.4",
        "symfony/yaml" : "^4.4 || ^5.4 || ^6.4 || ^7.4"
    },
    "config" : {
        "sort-packages" : true
    },
    "scripts" : {
        "php-cs-fixer" : "php-cs-fixer fix --config=.php-cs-fixer.dist.php -v --dry-run --stop-on-violation --using-cache=no"
    },
    "extra" : {
        "branch-alias" : {
            "dev-master" : "1.x-dev"
        },
        "symfony" : {
            "allow-contrib" : "true"
        }
    },
    "support" : {
        "docs" : "https://github.com/CedrickOka/doctrine-encrypt-bundle/blob/master/docs/index.md"
    }
}
